@@ -12,6 +12,26 @@
 #ifndef CUDA_RASTERIZER_AUXILIARY_H_INCLUDED
 #define CUDA_RASTERIZER_AUXILIARY_H_INCLUDED
 
+// MSVC's <math.h> hides M_PI/M_1_PI unless _USE_MATH_DEFINES is set
+// before the first include of any math header. The CUDA toolchain
+// pulls math.h transitively from cuda_runtime.h, so the macro has to
+// be visible before *anything* else.
+#ifndef _USE_MATH_DEFINES
+#define _USE_MATH_DEFINES
+#endif
+#include <cmath>
+#ifndef M_PI
+#define M_PI 3.14159265358979323846
+#endif
+#ifndef M_1_PI
+#define M_1_PI 0.318309886183790671538
+#endif
+// M_1_PIf32 is a glibc-only float32 spelling of 1/pi. MSVC has no
+// equivalent macro; define it explicitly.
+#ifndef M_1_PIf32
+#define M_1_PIf32 0.31830988618379067f
+#endif
+
 #include "config.h"
 #include "stdio.h"
 
